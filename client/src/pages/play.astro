---
import Layout from '../layouts/Layout.astro';
import SpaceInvaders from '../components/SpaceInvaders.svelte';
---

<Layout title="Play Space Invaders - Tailspin Toys">
  <section class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-bold text-slate-100 mb-2">Space Invaders</h1>
      <p class="text-slate-400">A classic arcade experience — defend Earth from the alien invasion!</p>
    </div>

    <SpaceInvaders client:only="svelte" />

    <div class="mt-12 flex justify-center">
      <a href="/" class="px-6 py-3 bg-slate-700 hover:bg-slate-600 text-white rounded-lg transition-all duration-300 hover:shadow-lg flex items-center" data-testid="back-to-games-link">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M9.707 14.707a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 1.414L7.414 9H15a1 1 0 110 2H7.414l2.293 2.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        Back to Games
      </a>
    </div>
  </section>
</Layout>
